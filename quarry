"""Quarry dataset-prep CLI entrypoint.

A thin launcher: it puts ``<repo>/scripts`` on sys.path and hands off to the
``quarry_tools`` package, which holds the argparse tree and every subcommand. Run
``./quarry --help`` for the command list.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent / "scripts"))

from quarry_tools.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
